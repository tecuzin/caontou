{
  "name": "cantou",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "rm -rf coverage-e2e && playwright test && node scripts/report-e2e-coverage.js",
    "test:appium": "wdio run tests/appium/wdio.conf.js",
    "quality": "bash scripts/quality-audit.sh",
    "test:bdd": "cucumber-js",
    "package:qa-bundle": "bash scripts/package-appium-bundle.sh"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@testing-library/dom": "^10.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@wdio/appium-service": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "jsdom": "^29.1.1",
    "vite": "^5.0.0",
    "vitest": "^4.1.9",
    "webdriverio": "^9.29.1"
  },
  "allowScripts": {
    "@capacitor/camera": true,
    "@capacitor/geolocation": true,
    "vitest": true,
    "@vitest/coverage-v8": true,
    "jsdom": true,
    "@testing-library/react": true,
    "@testing-library/jest-dom": true,
    "@testing-library/user-event": true,
    "@playwright/test": true,
    "esbuild": true,
    "rollup": true
  }
}
