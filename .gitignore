# Dépendances
node_modules/

# Sorties de build web
dist/

# Projet natif Android (régénéré par `npx cap add android`)
android/

# Artefacts APK
build/
*.apk
*.aab

# Gradle / SDK
.gradle/
local.properties
*.keystore
# Exception : keystore de sideload familial, committé pour garantir une
# signature STABLE entre les builds (sinon Android refuse la mise à jour :
# conflit de package). À remplacer par un vrai keystore hors-repo pour
# une éventuelle publication Play Store.
!cantou.keystore

# Divers
.DS_Store
*.log
*.bak
*.tmp

# Claude Code — local/runtime
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Credentials de déploiement (ne jamais committer)
.env.deploy
