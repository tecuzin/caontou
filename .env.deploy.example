# Credentials pour le déploiement Telegram
# Copier ce fichier en .env.deploy et remplir les valeurs.
# NE PAS committer .env.deploy (il est dans .gitignore).

# Token du bot Telegram (obtenu via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# ID du canal ou groupe de destination
# - Canal public  : @nomducanal
# - Canal privé   : -1001234567890  (obtenu via @userinfobot)
# - Chat direct   : votre user ID   (obtenu via @userinfobot)
TELEGRAM_CHAT_ID=@cantoubuilds
